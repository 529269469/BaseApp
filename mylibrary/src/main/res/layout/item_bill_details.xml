<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="40dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/ivIsShowScope"
        android:layout_width="31dp"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:paddingStart="10dp"
        android:paddingEnd="0dp"
        android:visibility="gone"
        android:src="@drawable/checkbox_true" />

    <TextView
        android:id="@+id/tvDetailsHint"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginStart="10dp"
        android:gravity="center_vertical"
        android:textColor="#000000"
        android:textSize="14sp"
        android:textStyle="bold"
        tools:text="提现金额：" />

    <TextView
        android:id="@+id/tvDetailsAmount"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="15dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:textColor="#ff8004"
        tools:text="￥ 100-5000" />

    <ImageView
        android:visibility="gone"
        android:id="@+id/iv_pitch_on"
        android:layout_width="45dp"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:paddingStart="9dp"
        android:paddingEnd="20dp"
        android:src="@mipmap/tixian_weixuanzhong" />

    <ImageView
        android:id="@+id/ivShowHint"
        android:layout_width="45dp"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:paddingStart="9dp"
        android:paddingEnd="20dp"
        android:src="@mipmap/lvsewenhao" />
</LinearLayout>